{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": ["ES2020", "DOM", "DOM.Iterable", "WebWorker"],
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@/*": ["./src/*"],
      "@tajarace/core": ["./src/vendor/tajarace/core/index.ts"],
      "@tajarace/content": ["./src/vendor/tajarace/content/index.ts"],
      "@tajarace/storage": ["./src/vendor/tajarace/storage/index.ts"],
      "@tajarace/racing": ["./src/vendor/tajarace/racing/index.ts"],
      "@tajarace/ui": ["./src/vendor/tajarace/ui/index.ts"]
    },
    "skipLibCheck": true,
    "strict": false,
    "target": "ES2020",
    "types": ["vitest/globals"],
    "useDefineForClassFields": true
  },
  "include": ["src"]
}
